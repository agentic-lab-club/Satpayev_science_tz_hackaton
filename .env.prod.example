# AWS Prod Secrets

# Frontend / internal service URLs
# Browser calls go through the Next.js proxy on the frontend host.
# Example: https://<cloudfront>/backend/docs -> http://backend:8080/docs
NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP:8080
BACKEND_INTERNAL_URL=http://backend:8080
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=8080

# Postgres
# Generates a high-entropy, base64-encoded string command:
# openssl rand -base64 32
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=satpayevtz
DB_USER=satpayevtz
DB_PASSWORD=change-me
DB_SSLMODE=disable

# Backend
# for it we use: /backend/config/config.prod.yaml

# AI Service
AI_SERVICE_ENV=production
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_SERVICE_LOG_LEVEL=info
AI_SERVICE_LLM_ENABLED=false
AI_SERVICE_LLM_PROVIDER=openai-compatible
AI_SERVICE_LLM_BASE_URL=
AI_SERVICE_LLM_API_KEY=
AI_SERVICE_LLM_MODEL=
AI_SERVICE_REQUEST_TIMEOUT_SECONDS=60
AI_SERVICE_MAX_INPUT_CHARS=120000
